[user]
    name = eneserciyes
    email = m.eneserciyes@gmail.com

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = simple
    autoSetupRemote = true   # needs git >= 2.37; older git ignores it

[fetch]
    prune = true

[color]
    ui = auto

[alias]
    s = status
    a = add
    aa = add -A
    c = commit -m
    co = checkout
    b = branch
    d = diff
    p = push
    pl = pull
    l = log --oneline --graph --decorate -20

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[credential "https://github.com"]
  helper =
  helper = !gh auth git-credential

[credential "https://gist.github.com"]
  helper =
  helper = !gh auth git-credential
