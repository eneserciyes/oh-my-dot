Match host *
  SetEnv TERM=xterm-256color
  ServerAliveInterval 30
  ServerAliveCountMax 3
  IdentitiesOnly yes
  IdentityFile ~/.ssh/id_ed25519
  LogLevel ERROR
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlPersist 600
  Compression yes
  AddKeysToAgent yes
  ConnectionAttempts 2


