// ~/.config/zellij/config.kdl
// Zellij — terminal multiplexer / window manager. Think of it as the "VSCode
// window" that holds your editor, an integrated terminal, and a file-manager
// pane in ONE ghostty window — and, crucially over SSH, keeps them alive if you
// disconnect (detach with Ctrl o, d; reattach later with `zellij attach`).
//
// Default keybindings are kept — they're discoverable from the on-screen status
// bar, which shows the Ctrl- prefixes. The essentials:
//   Ctrl p   PANE mode:   n new pane, x close, arrows move focus, d/r split down/right
//   Ctrl t   TAB mode:    n new tab, arrows switch, x close
//   Ctrl n   RESIZE mode
//   Ctrl s   SCROLL/SEARCH mode (e: edit scrollback in your editor)
//   Ctrl o   SESSION mode: d detach (keeps it running to reattach later)
//   Ctrl q   quit
// Dump the full default config (all keys) any time with:
//   zellij setup --dump-config

// Theme — "terminal" follows Ghostty's own colors: ANSI palette slots 0-15
// render with whatever Ghostty maps them to, so zellij's UI matches your
// terminal theme and tracks it if you change Ghostty later. (nvim themes its own
// pane via vscode.nvim.) For a fixed theme instead, set e.g. theme "tokyo-night"
// (catppuccin-mocha, gruvbox-dark, nord, ...).
theme "terminal"

themes {
    // 0-15 = the terminal's ANSI palette, which Ghostty controls.
    terminal {
        fg 7
        bg 0
        black 0
        red 1
        green 2
        yellow 3
        blue 4
        magenta 5
        cyan 6
        white 7
        orange 3
    }
}

// Open the VS Code-like workspace (nvim editor + terminal) for every session.
// Layouts live in ~/.config/zellij/layouts/. Alternatives:
//   zellij --layout wide   (editor left / terminal right;  alias: zjw)
//   zellij --layout shell  (plain shell, no nvim;          alias: zjs)
default_layout "default"

// Mouse support: click panes/tabs, select to copy, scroll. Works locally and
// over SSH in ghostty.
mouse_mode true

// Cleaner look: hide per-pane borders. Set true if you'd rather see frames
// (frames make the focused pane more obvious when you have many panes).
pane_frames false

// Copy behavior. With NO copy_command set, zellij copies via OSC52, which works
// over SSH (ghostty forwards it to your Mac's clipboard) — so leave it unset on
// remote boxes. On a LOCAL machine you can send copies straight to the system
// clipboard instead by uncommenting the matching line (put it in a per-machine
// override if it differs by host):
//   copy_command "pbcopy"                          // macOS
//   copy_command "wl-copy"                          // Linux / Wayland
//   copy_command "xclip -selection clipboard"       // Linux / X11
copy_clipboard "system"

// Use your login shell. Uncomment to force one regardless of $SHELL.
// default_shell "zsh"

// Edit scrollback / open the buffer in an editor with Ctrl s then `e`.
// No scrollback_editor set: zellij falls back to $EDITOR/$VISUAL, which the
// shell config points at nvim (or vim on boxes without it).
// scrollback_editor "/usr/bin/vim"   // uncomment to force a specific editor

// Remember pane/tab layout across restarts so a crashed/closed session can be
// resurrected (`zellij attach` lists resurrectable sessions).
session_serialization true

// On the OS trying to close the window, detach rather than kill the session.
on_force_close "detach"

// Let Ctrl+h reach Neovim in normal mode: nvim uses Ctrl+h/j/k/l to move between
// its splits, but zellij binds Ctrl+h to enter "Move" mode by default, which
// would shadow it. (Ctrl+j/k/l aren't bound by zellij, so they already pass
// through. Zellij's own pane navigation is on Alt+h/j/k/l.) Move mode is still
// reachable from other modes, e.g. Ctrl+p then Ctrl+h.
keybinds {
    normal {
        unbind "Ctrl h"
    }
}
